# Ключ 2ГИС MapGL (карта). Получить в Platform Manager: https://platform.2gis.ru/
# Для локальной разработки скопируйте этот файл в .env.local и впишите ключ.
# На Vercel добавьте такую же переменную в Project Settings → Environment Variables.
VITE_2GIS_API_KEY=

# Адрес бэкенда (аккаунты, друзья, чаты).
# Локально можно не указывать — по умолчанию http://localhost:4000.
# На сайте впиши адрес развёрнутого сервера, например https://api.localee.ru
VITE_API_URL=
