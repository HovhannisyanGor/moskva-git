# Скопируй этот файл в .env и при необходимости поменяй значения.
# Локально хватит значений по умолчанию. На хостинге поменяешь только этот файл — код трогать не нужно.

# Порт, на котором работает API
PORT=4000

# Секрет для подписи токенов (пропусков пользователей).
# На хостинге ОБЯЗАТЕЛЬНО замени на длинную случайную строку.
JWT_SECRET=dev-secret-change-me

# Путь к файлу базы данных (SQLite). База — это просто этот файл.
DB_PATH=./data/localee.db

# Каким сайтам разрешено обращаться к API.
# Локально: * (всем). На проде поставь адрес фронта, например https://localee.ru
CORS_ORIGIN=*
